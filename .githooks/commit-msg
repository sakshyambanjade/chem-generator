#!/usr/bin/env sh
set -eu

message_file=${1:?commit message file required}
tmp_file="${message_file}.cursor-strip.$$"

awk '
  {
    normalized = tolower($0)
    if (normalized ~ /^[[:space:]]*co-authored-by:[[:space:]]*(cursor|cursor agent|cursoragent)[[:space:]]*<cursoragent@cursor[.]com>[[:space:]]*$/) {
      next
    }
    if (normalized ~ /^[[:space:]]*made-with:[[:space:]]*cursor[[:space:]]*$/) {
      next
    }
    print
  }
' "$message_file" > "$tmp_file"

mv "$tmp_file" "$message_file"
